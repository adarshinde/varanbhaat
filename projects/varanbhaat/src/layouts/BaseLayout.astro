---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | varanbhaat</title>
    <meta name="description" content="Personal portfolio and blog" />
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-gray-900 hover:no-underline">
          varanbhaat
        </a>
        <div class="flex gap-6">
          <a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
          <a href="/blog" class="text-gray-700 hover:text-gray-900">Blog</a>
        </div>
      </div>
    </nav>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-gray-100 border-t border-gray-200 mt-12">
      <div class="max-w-4xl mx-auto px-4 py-8 text-center text-gray-600">
        <p>&copy; 2026 varanbhaat. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
