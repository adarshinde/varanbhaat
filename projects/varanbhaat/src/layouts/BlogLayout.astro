---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  topic: string;
}

const { title, date, topic } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4 text-gray-900">{title}</h1>
      <div class="flex items-center gap-4 text-gray-600">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
          {topic}
        </span>
      </div>
    </header>

    <div class="prose prose-lg max-w-none text-gray-800">
      <slot />
    </div>

    <hr class="my-12" />

    <a href="/blog" class="text-blue-600 hover:text-blue-800">← Back to blog</a>
  </article>
</BaseLayout>

<style>
  :global(.prose h2) {
    @apply text-3xl font-bold mt-8 mb-4;
  }

  :global(.prose h3) {
    @apply text-2xl font-bold mt-6 mb-3;
  }

  :global(.prose p) {
    @apply my-4 leading-relaxed;
  }

  :global(.prose ul),
  :global(.prose ol) {
    @apply my-4 pl-6;
  }

  :global(.prose li) {
    @apply my-2;
  }

  :global(.prose code) {
    @apply bg-gray-100 px-2 py-1 rounded text-sm font-mono;
  }

  :global(.prose pre) {
    @apply bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto my-4;
  }

  :global(.prose blockquote) {
    @apply border-l-4 border-blue-500 pl-4 italic my-4 text-gray-700;
  }
</style>