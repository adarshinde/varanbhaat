---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <!-- Hero Section -->
    <section class="mb-16">
      <h1 class="text-5xl font-bold mb-4 text-gray-900">Welcome</h1>
      <p class="text-xl text-gray-700 mb-6">
        This is my corner of the internet. Explore my thoughts on engineering,
        travel, and life.
      </p>
      <a
        href="/blog"
        class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
      >
        Read my blog
      </a>
    </section>

    <!-- Recent Posts -->
    {recentPosts.length > 0 && (
      <section>
        <h2 class="text-3xl font-bold mb-6 text-gray-900">Recent Posts</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => {
            const slug = post.id.replace(/\//g, '/');
            return (
              <a
                href={`/blog/${slug}`}
                class="p-6 bg-white rounded-lg shadow hover:shadow-lg transition-shadow"
              >
                <h3 class="text-xl font-semibold mb-2 text-gray-900">
                  {post.data.title}
                </h3>
                <p class="text-gray-600 mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-500">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </span>
                  <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs">
                    {post.data.topic}
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
